+static crispembed_log_callback g_log_callback = nullptr;
+static void * g_log_user_data = nullptr;
+
+static int crispembed_fprintf(FILE * stream, const char * format, ...) {
+    va_list args;
+    va_start(args, format);
+    if (stream == stderr && g_log_callback) {
+        char message[4096];
+        va_list copy;
+        va_copy(copy, args);
+        const int written = vsnprintf(message, sizeof(message), format, copy);
+        va_end(copy);
+        g_log_callback(message, g_log_user_data);
+        va_end(args);
+        return written;
+    }
+    const int written = vfprintf(stream, format, args);
+    va_end(args);
+    return written;
+}
+
+#define fprintf(stream, ...) crispembed_fprintf(stream, __VA_ARGS__)
