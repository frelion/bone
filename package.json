{
	"name": "bone-monorepo",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.14",
	"workspaces": [
		"packages/*",
		"packages/coding-agent/examples/extensions/with-deps",
		"packages/coding-agent/examples/extensions/custom-provider-anthropic",
		"packages/coding-agent/examples/extensions/custom-provider-gitlab-duo",
		"packages/coding-agent/examples/extensions/sandbox",
		"packages/coding-agent/examples/extensions/gondolin"
	],
	"scripts": {
		"clean": "bun run --filter '*' clean",
		"build": "bun run --cwd packages/tui build && bun run --cwd packages/ai build && bun run --cwd packages/agent build && bun run --cwd packages/coding-agent build && bun run --cwd packages/orchestrator build",
		"check": "biome check --write --error-on-warnings . && bun run check:pinned-deps && bun run check:ts-imports && bun run check:release-scripts && tsgo --noEmit && bun run check:examples && bun run check:browser-smoke",
		"check:browser-smoke": "bun scripts/check-browser-smoke.mjs",
		"check:examples": "tsgo -p packages/coding-agent/tsconfig.examples.json --noEmit",
		"check:pinned-deps": "bun scripts/check-pinned-deps.mjs",
		"check:release-scripts": "bun test scripts/*.test.mjs && bun scripts/sync-versions.js --check",
		"check:ts-imports": "bun scripts/check-ts-relative-imports.mjs",
		"generate:model-catalog": "bun run --cwd packages/ai generate-model-catalog",
		"check:model-catalog": "bun scripts/publish-model-catalog.mjs --input .artifacts/model-catalog --dry-run",
		"profile:tui": "bun scripts/profile-coding-agent-node.mjs --mode tui",
		"profile:rpc": "bun scripts/profile-coding-agent-node.mjs --mode rpc",
		"test": "bun run --filter '*' test",
		"eval:forge": "bun run --cwd packages/coding-agent eval:forge",
		"eval:forge:ci": "bun run --cwd packages/coding-agent eval:forge:ci",
		"eval:forge:live": "bun run --cwd packages/coding-agent eval:forge:live",
		"version:sync": "bun scripts/sync-versions.js",
		"prepublishOnly": "bun run clean && bun run build && bun run check",
		"publish": "bun -e \"throw new Error('Bone registry publishing is intentionally disabled; GitHub Releases are the distribution channel.')\"",
		"publish:dry": "bun -e \"throw new Error('Bone registry publishing is intentionally disabled; GitHub Releases are the distribution channel.')\"",
		"release:local": "bun scripts/local-release.mjs",
		"pack:bone": "bun scripts/pack-bone.mjs",
		"dev:install": "bun scripts/dev-bone.mjs install",
		"dev:install-hook": "bun scripts/dev-bone.mjs install-hook",
		"dev:uninstall-hook": "bun scripts/dev-bone.mjs uninstall-hook",
		"release:doctor": "bun scripts/release.mjs doctor",
		"release:prepare": "bun scripts/release.mjs prepare",
		"release:publish": "bun scripts/release.mjs publish",
		"release:fix-links": "bun scripts/release-notes.mjs fix-github-releases",
		"prepare": "bun scripts/dev-bone.mjs prepare"
	},
	"devDependencies": {
		"@anthropic-ai/sandbox-runtime": "0.0.26",
		"@biomejs/biome": "2.3.5",
		"@types/node": "22.19.19",
		"@typescript/native-preview": "7.0.0-dev.20260120.1",
		"esbuild": "0.28.1",
		"husky": "9.1.7",
		"jiti": "2.7.0",
		"shx": "0.4.0",
		"tsx": "4.22.1",
		"typescript": "5.9.3"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"version": "0.0.4",
	"overrides": {
		"rimraf": "6.1.2"
	}
}
