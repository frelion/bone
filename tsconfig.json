{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@frelion/bone-ai": ["./packages/ai/src/index.ts"],
			"@frelion/bone-ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@frelion/bone-ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
			"@frelion/bone-ai/dist/*": ["./packages/ai/src/*"],
			"@frelion/bone-agent-core": ["./packages/agent/src/index.ts"],
			"@frelion/bone-agent-core/*": ["./packages/agent/src/*"],
			"@frelion/bone-coding-agent": ["./packages/coding-agent/src/index.ts"],
			"@frelion/bone-coding-agent/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"@frelion/bone-coding-agent/*": ["./packages/coding-agent/src/*"],
			"@frelion/bone-orchestrator": ["./packages/orchestrator/src/index.ts"],
			"@frelion/bone-orchestrator/*": ["./packages/orchestrator/src/*"],
			"typebox": ["./node_modules/typebox"],
			"@frelion/bone-tui": ["./packages/tui/src/index.ts"],
			"@frelion/bone-tui/*": ["./packages/tui/src/*"],
			"@frelion/bone-agent-old": ["./packages/agent-old/src/index.ts"],
			"@frelion/bone-agent-old/*": ["./packages/agent-old/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*", "packages/coding-agent/examples/**/*"],
	"exclude": [
		"**/dist/**",
		"packages/coding-agent/examples/extensions/**",
		"packages/coding-agent/examples/sdk/06-extensions.ts",
		"packages/coding-agent/examples/sdk/12-full-control.ts",
		"packages/coding-agent/test/**"
	]
}
