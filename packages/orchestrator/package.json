{
	"name": "@frelion/bone-orchestrator",
	"version": "0.0.11",
	"description": "experimental orchestrator package for Bone",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"CHANGELOG.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"build": "tsgo -p tsconfig.build.json && shx chmod +x dist/cli.js",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"keywords": [
		"bone",
		"orchestrator"
	],
	"author": "Earendil Works",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/frelion/bone.git",
		"directory": "packages/orchestrator"
	},
	"engines": {
		"node": ">=22.19.0"
	},
	"dependencies": {
		"@frelion/bone-coding-agent": "^0.0.11"
	},
	"devDependencies": {
		"shx": "0.4.0"
	}
}
