{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"@frelion/bone-coding-agent": ["./src/index.ts"],
			"@frelion/bone-coding-agent/hooks": ["./src/core/hooks/index.ts"],
			"@frelion/bone-agent-core": ["../agent/src/index.ts"],
			"@frelion/bone-agent-core/*": ["../agent/src/*.ts"],
			"@frelion/bone-tui": ["../tui/src/index.ts"],
			"@frelion/bone-ai": ["../ai/src/index.ts"],
			"@frelion/bone-ai/compat": ["../ai/src/compat.ts"],
			"@frelion/bone-ai/*": ["../ai/src/*.ts", "../ai/src/providers/*.ts"],
			"typebox": ["../../node_modules/typebox"]
		},
		"skipLibCheck": true
	},
	"include": ["examples/**/*.ts", "src/**/*.d.ts"],
	"exclude": ["node_modules", "dist", "examples/**/test.ts"]
}
