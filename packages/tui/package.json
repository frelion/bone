{
	"name": "@frelion/bone-tui",
	"version": "0.1.4",
	"description": "Bun-native terminal UI primitives and renderer for Bone",
	"type": "module",
	"main": "dist/index.js",
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"test": "bun test ./test/*.test.ts ./test/*.bun.ts",
		"prepublishOnly": "bun run clean && bun run build"
	},
	"files": [
		"dist/**/*",
		"README.md"
	],
	"keywords": [
		"tui",
		"terminal",
		"ui",
		"text-editor",
		"opentui",
		"typescript",
		"cli"
	],
	"author": "Mario Zechner",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/frelion/bone.git",
		"directory": "packages/tui"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"types": "./dist/index.d.ts",
	"dependencies": {
		"@opentui/core": "0.4.5",
		"get-east-asian-width": "1.6.0",
		"web-tree-sitter": "0.25.10"
	}
}
